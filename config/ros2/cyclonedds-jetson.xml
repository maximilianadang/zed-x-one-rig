<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Jetson camera-publisher profile for field LANs.

  The compressed field samples are much larger than an Ethernet/Wi-Fi MTU.
  Keep each UDP payload below the 1500-byte link MTU so Cyclone DDS performs
  retransmittable DDSI fragmentation instead of the IP layer fragmenting a
  65.5-KiB datagram. User data is unicast; multicast is retained for discovery.
-->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface autodetermine="true" priority="default"
                          multicast="default" />
      </Interfaces>
      <AllowMulticast>spdp</AllowMulticast>
      <FragmentSize>1344B</FragmentSize>
      <MaxMessageSize>1400B</MaxMessageSize>
      <MaxRexmitMessageSize>1400B</MaxRexmitMessageSize>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
    </Discovery>
  </Domain>
</CycloneDDS>
