# Fixed defaults for the remote field console. Override these with command-line
# options or environment variables; do not encode SSID-specific addresses here.
ZED_FIELD_DEFAULT_JETSON="dusty@ubuntu.local"
ZED_FIELD_REMOTE_ROOT="/home/dusty/workspace/terraforming_mars/zed-x-one-rig"
ZED_FIELD_UNIT="zed-field-live.service"
ZED_FIELD_OUTPUT_DIR="/home/dusty/Videos/ZED"
ZED_FIELD_MIN_FREE_BYTES="21474836480"
# Conservative measured lossless write rate for storage-time estimates only.
ZED_FIELD_LOSSLESS_BYTES_PER_SEC="60000000"
ZED_FIELD_START_TIMEOUT="90"
ZED_FIELD_FINALIZE_TIMEOUT="120"
